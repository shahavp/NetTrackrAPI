{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "./Dockerfile.worker",
    "watchPatterns": [
      "requirements.txt",
      "requirements.worker.txt",
      "tracker.py",
      "worker.py",
      "jobs.py",
      "storage.py",
      "Dockerfile.worker",
      "railway.worker.json"
    ]
  },
  "deploy": {
    "restartPolicyType": "always",
    "restartPolicyMaxRetries": 5,
    "numReplicas": 1
  }
}
