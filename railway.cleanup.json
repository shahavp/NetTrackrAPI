{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "./Dockerfile.api",
    "watchPatterns": [
      "requirements.api.txt",
      "cleanup.py",
      "jobs.py",
      "storage.py",
      "Dockerfile.api",
      "railway.cleanup.json"
    ]
  },
  "deploy": {
    "cronSchedule": "0 * * * *",
    "restartPolicyType": "never"
  }
}
